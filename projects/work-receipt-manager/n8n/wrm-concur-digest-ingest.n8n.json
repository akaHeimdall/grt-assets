    },
    "Outlook — Get Concur Digests": {
      "main": [[{ "node": "Map cardLast4 from subject", "type": "main", "index": 0 }]]
    },
    "Map cardLast4 from subject": {
      "main": [[{ "node": "Digest body → digestText", "type": "main", "index": 0 }]]
    },
    "Digest body → digestText": {
      "main": [[{ "node": "WRM API — digest:ingest", "type": "main", "index": 0 }]]
    },
    "WRM API — digest:ingest": {
      "main": [[{ "node": "Outlook — Mark processed (read + category)", "type": "main", "index": 0 }]]
    },
    "Outlook — Mark processed (read + category)": {
      "main": [[{ "node": "Outlook — Move to Finance/Receipts", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
